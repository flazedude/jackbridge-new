<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JackBridge.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="JackBridge.GUI.Views.HomeView"
        x:DataType="vm:HomeViewModel"
        Background="#FF1d1d1f">

    <UserControl.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="400"/>
            <Setter Property="Foreground" Value="#FF7a7a7a"/>
        </Style>
        <Style Selector="Button.statsCard">
            <Setter Property="Background" Value="#FF2a2a2c"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.statsCard:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#FF363639"/>
            <Setter Property="CornerRadius" Value="14"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="32,24">
        <!-- Top row: Welcome + toggle | Stats -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="48" Margin="0,0,0,24">
            <!-- Left: Welcome + status + toggle -->
            <StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Border Width="8" Height="8"
                            CornerRadius="4"
                            Background="{Binding ProxyStatusColor}"/>
                    <TextBlock Text="{Binding ProxyStatusText}"
                               FontSize="15"
                               FontWeight="600"
                               Foreground="#FFFFFFFF"/>
                </StackPanel>
                <TextBlock Text="Welcome to JackBridge"
                           FontSize="22"
                           FontWeight="600"
                           Foreground="#FFFFFFFF"/>
                <TextBlock Text="Secure traffic interception for your applications"
                           FontSize="13"
                           Foreground="#FFcccccc"/>

            </StackPanel>

            <!-- Right: At a glance stats -->
            <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="12" VerticalAlignment="Center">
                <Button Grid.Column="0"
                        Classes="statsCard"
                        Command="{Binding OpenRulesCommand}"
                        MinWidth="130">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Active Rules" Classes="label"/>
                        <TextBlock Text="{Binding ActiveRulesCount}"
                                   FontSize="28"
                                   FontWeight="600"
                                   Foreground="#FFFFFFFF"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1"
                        Classes="statsCard"
                        Command="{Binding OpenSettingsCommand}"
                        MinWidth="130">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Proxy Route" Classes="label"/>
                        <TextBlock Text="{Binding EngineType}"
                                   FontSize="28"
                                   FontWeight="600"
                                   Foreground="#FFFFFFFF"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>

        <!-- Bottom: Activity + Connections side by side -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="16">
            <!-- Activity Log -->
            <Border Grid.Column="0"
                    Background="#FF272729"
                    CornerRadius="14"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Activity"
                               FontSize="14"
                               FontWeight="600"
                               Foreground="#FFFFFFFF"
                               Margin="0,0,0,10"/>
                    <Border Background="#FF1d1d1f"
                            CornerRadius="6"
                            Padding="10">
                        <ScrollViewer x:Name="ActivityScroller"
                                      ScrollChanged="OnLogScrollChanged">
                            <TextBlock x:Name="ActivityLogText"
                                       Text="{Binding RecentActivity}"
                                       FontSize="11"
                                       Foreground="#FF7a7a7a"
                                       FontFamily="Consolas,monospace"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding RecentActivity, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Connections Log -->
            <Border Grid.Column="1"
                    Background="#FF272729"
                    CornerRadius="14"
                    Padding="16">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Connections"
                               FontSize="14"
                               FontWeight="600"
                               Foreground="#FFFFFFFF"
                               Margin="0,0,0,10"/>
                    <Border Background="#FF1d1d1f"
                            CornerRadius="6"
                            Padding="10">
                        <ScrollViewer x:Name="ConnectionsScroller"
                                      ScrollChanged="OnLogScrollChanged">
                            <TextBlock x:Name="ConnectionsLogText"
                                       Text="{Binding RecentConnections}"
                                       FontSize="11"
                                       Foreground="#FF7a7a7a"
                                       FontFamily="Consolas,monospace"
                                       TextWrapping="Wrap"
                                       IsVisible="{Binding RecentConnections, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </ScrollViewer>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
